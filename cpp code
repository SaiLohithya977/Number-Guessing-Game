#include <iostream>
#include <cstdlib>
#include <ctime>

using namespace std;

int main() {
    srand(time(0));

    int secretNumber = rand() % 1000 + 1;
    int guess;
    int attempts = 10;

    cout << "Guess the number (1-1000)\n";
    cout << "You have 10 attempts.\n";

    while (attempts > 0) {
        cout << "\nEnter guess: ";
        cin >> guess;

        if (guess == secretNumber) {
            cout << "Congratulations! You guessed the number.\n";
            return 0;
        }
        else if (guess < secretNumber) {
            cout << "The number is ABOVE " << guess << ".\n";
        }
        else {
            cout << "The number is BELOW " << guess << ".\n";
        }

        attempts--;
        cout << "Attempts left: " << attempts << endl;
    }

    cout << "\nGame Over! The number was "
         << secretNumber << ".\n";

    return 0;
}
